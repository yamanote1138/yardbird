# YardBird Configuration
# Copy this file to .env.local and uncomment the values you need.
# In dev mode, prefix with VITE_YB_*. In Docker, use YB_* (see compose.yaml).

# JMRI Connection
# VITE_YB_JMRI_HOST=raspi-jmri.local
# VITE_YB_JMRI_PORT=12080
# VITE_YB_JMRI_SECURE=false

# Demo / Debug
# VITE_YB_MOCK=false
# VITE_YB_DEBUG=false

# DCC-EX Proxy (used by dev:all to connect proxy to CommandStation)
# DCCEX_HOST=192.168.1.231
# DCCEX_PORT=2560

# DCC-EX Tram Control (app-side config)
# VITE_YB_DCCEX_ENABLED=false
# VITE_YB_DCCEX_HOST=localhost
# VITE_YB_DCCEX_PORT=2561
# VITE_YB_DCCEX_PWM_FREQ=3

# Home Assistant
# VITE_YB_HA_ENABLED=false
# VITE_YB_HA_URL=http://homeassistant.local:8123
# VITE_YB_HA_TOKEN=your_long_lived_access_token
# VITE_YB_HA_AREA=train_room
